# WooCommerce API — server-to-server only, NEVER use VITE_ prefix
WC_URL=https://heyskipper.com
WC_CONSUMER_KEY=ck_your_consumer_key_here
WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# Simple JWT Login plugin secret — must match WooCommerce > Simple JWT Login > General > Decryption Key
JWT_SECRET=your_jwt_secret_here

# Stripe — secret key only
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# CORS allowed origins
FRONTEND_URL=http://localhost:5173
FRONTEND_STAGING_URL=https://hs-mock-demo-production.up.railway.app
FRONTEND_PRODUCTION_URL=https://heyskipper.com

# Runtime
NODE_ENV=development
PORT=3000
